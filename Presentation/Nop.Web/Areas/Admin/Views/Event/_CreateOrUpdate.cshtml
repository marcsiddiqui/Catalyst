@model EventModel

@{
    const string hideInfoBlockAttributeName = "EventPage.HideInfoBlock";
    const string hideAcademicYearGradeSectionEventMappingBlockAttributeName = "EventPage.AcademicYearGradeSectionEventMappingBlock";
    var customer = await workContext.GetCurrentCustomerAsync();
    var hideInfoBlock = await genericAttributeService.GetAttributeAsync<bool>(customer, hideInfoBlockAttributeName);
    var hideAcademicYearGradeSectionEventMappingBlock = await genericAttributeService.GetAttributeAsync<bool>(customer, hideAcademicYearGradeSectionEventMappingBlockAttributeName);
}

<div asp-validation-summary="All"></div>
<input asp-for="Id" type="hidden" />

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <nop-cards id="event-cards">
                <nop-card asp-name="event-info" asp-icon="fas fa-info" asp-title="@T("Admin.HolidaysNEvents.Events.Info")" asp-hide-block-attribute-name="@hideInfoBlockAttributeName" asp-hide="@hideInfoBlock" asp-advanced="false">@await Html.PartialAsync("_CreateOrUpdate.Info", Model)</nop-card>
                <nop-card asp-name="event-academic-year-grade-section-mapping" asp-icon="fas fa-school" asp-title="@T("Admin.HolidaysNEvents.Events.AcademicYearGradeSectionEventMapping")" asp-hide-block-attribute-name="@hideAcademicYearGradeSectionEventMappingBlockAttributeName" asp-hide="@hideAcademicYearGradeSectionEventMappingBlock" asp-advanced="false">@await Html.PartialAsync("_AcademicYearGradeSectionEventMapping", Model)</nop-card>
            </nop-cards>
        </div>
    </div>
</section>
