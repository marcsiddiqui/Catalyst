@using Nop.Web.Areas.Admin.Models.Admissions
@model AdmissionGradeDocumentRequirementModel

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-popup">
                    <div class="card-body">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="GradeId" />

                        @if (Model.Id > 0)
                        {
                            <div class="form-group row">
                                <div class="col-sm-3">
                                    <nop-label asp-for="AdmissionDocumentTypeId" />
                                </div>
                                <div class="col-sm-9">
                                    <nop-select asp-for="AdmissionDocumentTypeId" asp-items="Model.AvailableAdmissionDocumentTypes" />
                                    <span asp-validation-for="AdmissionDocumentTypeId"></span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="form-group row">
                                <div class="col-sm-3">
                                    <nop-label asp-for="SelectedAdmissionDocumentTypeIds" />
                                </div>
                                <div class="col-sm-9">
                                    <nop-select asp-for="SelectedAdmissionDocumentTypeIds" asp-items="Model.AvailableAdmissionDocumentTypes" asp-multiple="true" />
                                    <span asp-validation-for="SelectedAdmissionDocumentTypeIds"></span>
                                </div>
                            </div>
                        }

                        <div class="form-group row">
                            <div class="col-sm-3">
                                <nop-label asp-for="IsRequired" />
                            </div>
                            <div class="col-sm-9">
                                <nop-editor asp-for="IsRequired" />
                                <span asp-validation-for="IsRequired"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    $(function () {
        @if (Model.Id == 0)
        {
            <text>
                var $documentTypeEl = $('#@Html.IdFor(m => m.SelectedAdmissionDocumentTypeIds)');

                if ($documentTypeEl.data('kendoMultiSelect')) {
                    $documentTypeEl.data('kendoMultiSelect').destroy();
                }

                $documentTypeEl.kendoMultiSelect({
                    autoClose: false,
                    placeholder: '@(Model.AvailableAdmissionDocumentTypes.Any() ? "Select documents..." : "No document types available")',
                    enable: @(Model.AvailableAdmissionDocumentTypes.Any() ? "true" : "false")
                });
            </text>
        }
    });

    function saveAdmissionGradeDocumentRequirement() {
        var isEdit = @(Model.Id > 0 ? "true" : "false");

        var payload = {
            Id: @Model.Id,
            GradeId: $('#@Html.IdFor(m => m.GradeId)').val(),
            IsRequired: $('#@Html.IdFor(m => m.IsRequired)').is(':checked')
        };

        if (isEdit) {
            payload.AdmissionDocumentTypeId = parseInt($('#@Html.IdFor(m => m.AdmissionDocumentTypeId)').val()) || 0;
        } else {
            payload.SelectedAdmissionDocumentTypeIds = $('#@Html.IdFor(m => m.SelectedAdmissionDocumentTypeIds)').val();
        }

        $.ajax({
            url: '@Url.Action("AdmissionGradeDocumentRequirementSave", "Grade")',
            type: 'POST',
            data: payload,
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function (response) {
                if (response.Result === 'success') {
                    if (response.Warnings && response.Warnings.length > 0) {
                        alert('Saved with warnings:\n' + response.Warnings.join('\n'));
                    }

                    window.opener.$('#btnRefreshAdmissionDocumentRequirement').click();
                    window.close();
                } else {
                    var errors = response.Errors || ['An error occurred.'];
                    alert(errors.join('\n'));
                }
            },
            error: function (xhr) {
                alert('Request failed: ' + xhr.statusText);
            }
        });
    }
</script>
