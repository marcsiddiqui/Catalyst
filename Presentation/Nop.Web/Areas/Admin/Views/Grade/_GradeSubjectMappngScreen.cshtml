@using Nop.Web.Areas.Admin.Models.GradeManagement
@model GradeModel

<div class="card card-default">
    <div class="card-header">
        @T("Admin.Grade.Subject.Mapping")
    </div>
    @if (Model.Id > 0)
    {
        <div class="card-body">
            <p>
                @T("Admin.Grade.Subject.Mapping.Hint")
            </p>
            @await Html.PartialAsync("Table", new DataTablesModel
            {
                Name = "gradeSubjectMapping-grid",
                UrlRead = new DataUrl("GradeSubjectGrid", "Grade", new RouteValueDictionary { [nameof(Model.GradeSubjectSearchModel.GradeId)] = Model.GradeSubjectSearchModel.GradeId }),
                UrlDelete = new DataUrl("GradeSubjectDelete", "Grade", null),
                Length = Model.GradeSubjectSearchModel.PageSize,
                LengthMenu = Model.GradeSubjectSearchModel.AvailablePageSizes,
                ColumnCollection = new List<ColumnProperty>
                {
                    new ColumnProperty(nameof(GradeSubjectMappingModel.SubjectName))
                    {
                        Title = T("Admin.Grade.Subject.Mapping.SubjectName").Text
                    },
                    new ColumnProperty(nameof(GradeSubjectMappingModel.LabFee))
                    {
                        Title = T("Admin.Grade.Subject.Mapping.LabFee").Text
                    },
                    new ColumnProperty(nameof(GradeSubjectMappingModel.SectionName))
                    {
                        Title = T("Admin.Grade.Subject.Mapping.SectionName").Text
                    },
                    new ColumnProperty(nameof(GradeSubjectMappingModel.Id))
                    {
                        Title = T("Admin.Common.Edit").Text,
                        Width = "100",
                        ClassName =  NopColumnClassDefaults.Button,
                        Render = new RenderCustom("renderGradeSubjectEditColumn")
                    },
                    new ColumnProperty(nameof(GradeSubjectMappingModel.Id))
                    {
                        Title = T("Admin.Common.Delete").Text,
                        Width = "100",
                        Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                        ClassName =  NopColumnClassDefaults.Button
                    }
                }
            })
            <script>
                function renderGradeSubjectEditColumn(data, type, row, meta) {
                    return '<button onclick=\"javascript:OpenWindow(\'@Url.Content("~/Admin/Grade/AddOrEditGradeSubjectMappingPopup/")' + data + '?gradeId=' + @Model.Id + '&mappingId=' + row.Id + '\', 800, 600, true); return false;\" class="btn btn-default"><i class="fas fa-pencil"></i>@T("Admin.Common.Edit").Text</button>';
                }
            </script>
        </div>
        <div class="card-footer">
            <button type="submit" id="btnAddNewTierPrice" onclick="javascript:OpenWindow('@(Url.Action("AddOrEditGradeSubjectMappingPopup", "Grade", new { gradeId = Model.Id, mappingId = 0}))', 800, 600, true); return false;" class="btn btn-primary">
                @T("Admin.Grade.Subject.Mapping.AddNew")
            </button>
            <button type="submit" id="btnAddNewGradeSubjectMapping" style="display: none"></button>
            <script>
                $(function() {
                    $('#btnAddNewGradeSubjectMapping').click(function () {
                    updateTable('#gradeSubjectMapping-grid');
                        //return false to don't reload a page
                        return false;
                    });
                });
            </script>
        </div>
    }
    else
    {
        <div class="card-body">
            @T("Admin.Grade.Subject.Mapping.TierPrices.SaveBeforeEdit")
        </div>
    }
</div>