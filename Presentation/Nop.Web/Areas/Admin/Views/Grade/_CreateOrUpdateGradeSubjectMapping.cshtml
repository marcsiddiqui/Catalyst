@using Nop.Web.Areas.Admin.Models.GradeManagement
@model GradeSubjectMappingModel

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-popup">
                    <div class="card-body">
                        <input type="hidden" asp-for="@Model.Id" />
                        <input type="hidden" asp-for="@Model.GradeId" />
                        @if (Model.Id > 0)
                        {
                            <div class="form-group row">
                                <div class="col-sm-3">
                                    <nop-label asp-for="SubjectId" />
                                </div>
                                <div class="col-sm-9">
                                    <nop-select asp-for="SubjectId" asp-items="Model.AvailableSubjects" />
                                    <span asp-validation-for="SubjectId"></span>
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-sm-3">
                                    <nop-label asp-for="SectionId" />
                                </div>
                                <div class="col-sm-9">
                                    <nop-select asp-for="SectionId" asp-items="Model.AvailableSections" />
                                    <span asp-validation-for="SectionId"></span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="form-group row">
                                <div class="col-sm-3">
                                    <nop-label asp-for="SelectedSubjectIds" />
                                </div>
                                <div class="col-sm-9">
                                    <nop-select asp-for="SelectedSubjectIds" asp-items="Model.AvailableSubjects" asp-multiple="true" />
                                    <span asp-validation-for="SelectedSubjectIds"></span>
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-sm-3">
                                    <nop-label asp-for="SelectedSectionIds" />
                                </div>
                                <div class="col-sm-9">
                                    <nop-select asp-for="SelectedSectionIds" asp-items="Model.AvailableSections" asp-multiple="true" />
                                    <span asp-validation-for="SelectedSectionIds"></span>
                                </div>
                            </div>
                        }

                        <div class="form-group row">
                            <div class="col-sm-3">
                                <nop-label asp-for="LabFee" />
                            </div>
                            <div class="col-sm-9">
                                <nop-editor asp-for="LabFee" />
                                <span asp-validation-for="LabFee"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    $(function () {
        @if (Model.Id == 0)
        {
            <text>
                var $subjectEl = $('#@Html.IdFor(m => m.SelectedSubjectIds)');
                var $sectionEl = $('#@Html.IdFor(m => m.SelectedSectionIds)');

                if ($subjectEl.data('kendoMultiSelect')) {
                    $subjectEl.data('kendoMultiSelect').destroy();
                }
                if ($sectionEl.data('kendoMultiSelect')) {
                    $sectionEl.data('kendoMultiSelect').destroy();
                }

                $subjectEl.kendoMultiSelect({
                    autoClose: false,
                    placeholder: '@(Model.AvailableSubjects.Any() ? "Select subjects..." : "No subjects available")',
                    enable: @(Model.AvailableSubjects.Any() ? "true" : "false")
                });

                $sectionEl.kendoMultiSelect({
                    autoClose: false,
                    placeholder: '@(Model.AvailableSections.Any() ? "Select sections..." : "No sections available")',
                    enable: @(Model.AvailableSections.Any() ? "true" : "false")
                });
            </text>
        }
    });

    function saveGradeSubjectMapping() {
        var isEdit = @(Model.Id > 0 ? "true" : "false");

        var payload = {
            Id: @Model.Id,
            GradeId: $("#GradeId").val(),
            LabFee: parseFloat($('#@Html.IdFor(m => m.LabFee)').val()) || 0
        };

        if (isEdit) {
            payload.SubjectId = parseInt($('#@Html.IdFor(m => m.SubjectId)').val()) || 0;
            payload.SectionId = parseInt($('#@Html.IdFor(m => m.SectionId)').val()) || null;
        } else {
            payload.SelectedSubjectIds = $('#SelectedSubjectIds').val();
            payload.SelectedSectionIds = $('#SelectedSectionIds').val();
        }

        console.log("payload", payload);

        $.ajax({
            url: '@Url.Action("GradeSubjectMappingSave", "Grade")',
            type: 'POST',
            data: payload,
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function (response) {
                if (response.Result === 'success') {
                    if (response.Warnings && response.Warnings.length > 0) {
                        alert('Saved with warnings:\n' + response.Warnings.join('\n'));
                    }
                    // Close popup and trigger button on parent window
                    window.opener.$("#btnAddNewGradeSubjectMapping").click();
                    window.close();
                } else {
                    var errors = response.Errors || ['An error occurred.'];
                    alert(errors.join('\n'));
                }
            },
            error: function (xhr) {
                alert('Request failed: ' + xhr.statusText);
            }
        });
    }
</script>