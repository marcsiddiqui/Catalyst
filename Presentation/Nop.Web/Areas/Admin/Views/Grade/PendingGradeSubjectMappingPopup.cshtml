@using Nop.Web.Areas.Admin.Models.GradeManagement
@model GradeModel

@{
    Layout = "_AdminPopupLayout";

    //page title
    ViewBag.PageTitle = T("Admin.GradeManagement.Grades.AddNew").Text;
}

<div class="card card-default">
    <div class="card-header">
        @T("Admin.Grade.Subject.Mapping")
    </div>
    <div class="card-body">
        <p>
            @T("Admin.Grade.Subject.Mapping.Hint")
        </p>
        @await Html.PartialAsync("Table", new DataTablesModel
        {
            Name = "gradeSubjectMapping-grid",
            UrlRead = new DataUrl("GradeSubjectGrid", "Grade", new RouteValueDictionary { [nameof(Model.GradeSubjectSearchModel.GradeId)] = Model.GradeSubjectSearchModel.GradeId }),
            UrlDelete = new DataUrl("GradeSubjectDelete", "Grade", null),
            Length = Model.GradeSubjectSearchModel.PageSize,
            LengthMenu = Model.GradeSubjectSearchModel.AvailablePageSizes,
            ColumnCollection = new List<ColumnProperty>
            {
                new ColumnProperty(nameof(GradeSubjectModel.Id))
                {
                    IsMasterCheckBox = true,
                    Render = new RenderCheckBox("checkbox_academicYears"),
                    ClassName =  NopColumnClassDefaults.CenterAll,
                    Width = "50"
                },
                new ColumnProperty(nameof(GradeSubjectModel.SubjectName))
                {
                    Title = T("Admin.Grade.Subject.Mapping.SubjectName").Text
                },
                new ColumnProperty(nameof(GradeSubjectModel.LabFee))
                {
                    Title = T("Admin.Grade.Subject.Mapping.LabFee").Text,
                    Render = new RenderCustom("renderLabFeeInput")
                },
                new ColumnProperty(nameof(GradeSubjectModel.SectionName))
                {
                    Title = T("Admin.Grade.Subject.Mapping.SectionName").Text
                },
            }
        })

    </div>
    <button type="button" id="saveLabFees" class="btn btn-primary mt-2">
        @T("Admin.Grade.Subject.Mapping.SaveSelected")
    </button>
    <script>
                // Renders an always-visible number input for LabFee
        function renderLabFeeInput(data, type, row, meta) {
            return '<input type="number" '
                 + 'class="form-control lab-fee-input" '
                 + 'style="width:100px;" '
                 + 'min="0" step="0.01" '
                 + 'value="' + (data !== null && data !== undefined ? data : 0) + '" '
                 + 'data-id="' + row.Id + '" />';
        }

        // Save Selected button click
        $('#saveLabFees').on('click', function () {
            var items = [];

            // Loop only checked rows
            $('#gradeSubjectMapping-grid tbody input[name="checkbox_gradeSubject"]:checked')
                .each(function () {
                    var row = $(this).closest('tr');
                    var id  = $(this).val();                              // row Id from checkbox value
                    var fee = row.find('input.lab-fee-input').val();      // LabFee from our custom input

                    items.push({
                        Id:     parseInt(id),
                        LabFee: parseFloat(fee) || 0
                    });
                });

            if (items.length === 0) {
                showAlert('Please select at least one row.', 'error');
                return;
            }

            addAntiForgeryToken({ items: JSON.stringify(items) });  // nopCommerce helper

            $.ajax({
                url:  '@Url.Action("SaveGradeSubjectLabFees", "Grade")',
                type: 'POST',
                data: addAntiForgeryToken({ items: JSON.stringify(items) }),
                success: function (result) {
                    if (result.Result === 'error') {
                        showAlert(result.ErrorMessages.join('<br/>'), 'error');
                    } else {
                        showAlert('@T("Admin.Common.Saved")', 'success');
                        $('#gradeSubjectMapping-grid').DataTable().ajax.reload();
                    }
                },
                error: function () {
                    showAlert('An error occurred.', 'error');
                }
            });
        });
    </script>
</div>