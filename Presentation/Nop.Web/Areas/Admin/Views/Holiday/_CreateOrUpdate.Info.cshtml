@model HolidayModel

<div class="card-body">
    @(await Html.LocalizedEditorAsync<HolidayModel, HolidayLocalizedModel>("holiday-info-localized",
        @<div>
        <div class="form-group row">
            <div class="col-md-3">
                <nop-label asp-for="@Model.Locales[item].Name" />
            </div>
            <div class="col-md-9">
                <nop-editor asp-for="@Model.Locales[item].Name" />
                <span asp-validation-for="@Model.Locales[item].Name"></span>
            </div>
        </div>


        <div>
            <input type="hidden" asp-for="@Model.Locales[item].LanguageId" />
        </div>
    </div>
        ,
        @<div>
        <div class="form-group row">
            <div class="col-md-3">
                <nop-label asp-for="Name" />
            </div>
            <div class="col-md-9">
                <nop-editor asp-for="Name" asp-required="true" />
                <span asp-validation-for="Name"></span>
            </div>
        </div>

    </div>

        ))
    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="AcademicYearId" />
        </div>
        <div class="col-md-9">
            <nop-select asp-for="AcademicYearId" asp-items="Model.AvailableYears" />
            <span asp-validation-for="AcademicYearId"></span>
        </div>
    </div>

    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="Name" />
        </div>
        <div class="col-md-9">
            <nop-editor asp-for="Name" />
            <span asp-validation-for="Name"></span>
        </div>
    </div>

    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="Description" />
        </div>
        <div class="col-md-9">
            <nop-editor asp-for="Description" />
            <span asp-validation-for="Description"></span>
        </div>
    </div>

    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="DateFromUtc" />
        </div>
        <div class="col-md-9">
            <nop-editor asp-for="DateFromUtc" />
            <span asp-validation-for="DateFromUtc"></span>
        </div>
    </div>

    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="DateToUtc" />
        </div>
        <div class="col-md-9">
            <nop-editor asp-for="DateToUtc" />
            <span asp-validation-for="DateToUtc"></span>
        </div>
    </div>
    @if (Model.Id > 0)
    {
        <div class="form-group row">
            <div class="col-md-3">
                <nop-label asp-for="CreatedByName" />
            </div>
            <div class="col-md-9 align-content-center">
                @Model.CreatedByName
            </div>
        </div>

        <div class="form-group row">
            <div class="col-md-3">
                <nop-label asp-for="CreatedOnUtc" />
            </div>
            <div class="col-md-9 align-content-center">
                @Model.CreatedOnUtc
            </div>
        </div>

        <div class="form-group row">
            <div class="col-md-3">
                <nop-label asp-for="UpdatedByName" />
            </div>
            <div class="col-md-9 align-content-center">
                @Model.UpdatedByName
            </div>
        </div>

        <div class="form-group row">
            <div class="col-md-3">
                <nop-label asp-for="UpdatedOnUtc" />
            </div>
            <div class="col-md-9 align-content-center">
                @Model.UpdatedOnUtc
            </div>
        </div>
    }
</div>