@using Nop.Web.Areas.Admin.Models.Admissions
@model AdmissionModel

@{
    //page title
    ViewBag.PageTitle = T("Admin.Admissions.Admissions.AddNew").Text;
    //active menu item (system name)
    NopHtml.SetActiveMenuItemSystemName("Admissions");
}

<form asp-controller="Admission" asp-action="Create" method="post" id="admission-form">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Admin.Admissions.Admissions.AddNew") 
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-action="List">@T("Admin.Admissions.Admissions.BackToList")</a>
            </small>
        </h1>
    </div>
    @await Html.PartialAsync("_CreateOrUpdate", Model)
</form>
