                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="GuardianQaulification" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.GuardianQaulification), FieldId = Html.IdFor(model => model.GuardianQaulification), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableQualifications, SelectedValue = Model.GuardianQaulification.ToString(), Category = GenericDropdownEntity.Qualification.ToString() })<span asp-validation-for="GuardianQaulification"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="GuardianPhoneNo" /></div><div class="col-md-9">@await Html.PartialAsync("_PhoneNumberInput", new PhoneNumberInputModel { FieldName = nameof(Model.GuardianPhoneNo), FieldId = Html.IdFor(model => model.GuardianPhoneNo), Value = Model.GuardianPhoneNo })<span asp-validation-for="GuardianPhoneNo"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="GuardianProfession" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.GuardianProfession), FieldId = Html.IdFor(model => model.GuardianProfession), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableProfessions, SelectedValue = Model.GuardianProfession.ToString(), Category = GenericDropdownEntity.Profession.ToString() })<span asp-validation-for="GuardianProfession"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="GuardianMonthlyIncome" /></div><div class="col-md-9"><nop-editor asp-for="GuardianMonthlyIncome" /><span asp-validation-for="GuardianMonthlyIncome"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="Guardian_MontherTongue" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.Guardian_MontherTongue), FieldId = Html.IdFor(model => model.Guardian_MontherTongue), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableMotherTongues, SelectedValue = Model.Guardian_MontherTongue.ToString(), Category = GenericDropdownEntity.MotherTounge.ToString() })<span asp-validation-for="Guardian_MontherTongue"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="GuardianNationality" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.GuardianNationality), FieldId = Html.IdFor(model => model.GuardianNationality), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableNationalities, SelectedValue = Model.GuardianNationality.ToString(), Category = GenericDropdownEntity.Nationality.ToString() })<span asp-validation-for="GuardianNationality"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="GuardianReligion" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.GuardianReligion), FieldId = Html.IdFor(model => model.GuardianReligion), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableReligions, SelectedValue = Model.GuardianReligion.ToString(), Category = GenericDropdownEntity.Religion.ToString() })<span asp-validation-for="GuardianReligion"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="GuardianBloodGroup" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.GuardianBloodGroup), FieldId = Html.IdFor(model => model.GuardianBloodGroup), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableBloodGroups, SelectedValue = Model.GuardianBloodGroup.ToString(), Category = GenericDropdownEntity.BloodGroup.ToString() })<span asp-validation-for="GuardianBloodGroup"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="GuardianCaste" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.GuardianCaste), FieldId = Html.IdFor(model => model.GuardianCaste), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableCastes, SelectedValue = Model.GuardianCaste.ToString(), Category = GenericDropdownEntity.Caste.ToString() })<span asp-validation-for="GuardianCaste"></span></div></div>
            </div>

            <div class="admission-step-panel" data-admission-panel="6" style="display:none">
                <div id="admission-documents-empty" class="alert alert-info" style="display:none">No documents are configured for the selected grade.</div>
                <div id="admission-documents-loading" class="text-muted" style="display:none">Loading documents...</div>
                <div id="admission-documents-list"></div>
            </div>

            <div class="text-right mt-3">
                <button type="button" class="btn btn-primary" id="admission-save-step">
                    <i class="far fa-floppy-disk"></i>
                    Save and Continue
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    $(function () {
        var currentStep = 1;
        var loadingFormNo = false;
        var documentsLoadedForAdmissionId = 0;
        var pictureLoadedForAdmissionId = 0;
        var documentPonds = {};
        var studentPicturePond = null;
        var $alert = $('#admission-step-alert');

        function showError(message) {
            $alert.text(message).show();
        }

        function clearError() {
            $alert.hide().text('');
        }

        function selectedGuardianText() {
            var $wrapper = $('#@Html.IdFor(model => model.GuardianTypeId)').closest('.ss-wrapper');
            return $.trim($wrapper.find('.ss-trigger-text').text()).toLowerCase();
        }

        function guardianIsOther() {
            return selectedGuardianText() === 'other';
        }

        function refreshGuardianStep() {
            $('#guardian-step-link').toggle(guardianIsOther());
            if (!guardianIsOther() && currentStep === 5) {
                showStep(4);
            }
        }

        function showStep(step) {
            currentStep = step;
            $('.admission-step-panel').hide();
            $('[data-admission-panel="' + step + '"]').show();
            $('.admission-step-list button').removeClass('active');
            $('[data-admission-step="' + step + '"]').addClass('active');
            $('#admission-save-step').toggle(step > 0);
            refreshGuardianStep();
            if (step === 6) {
                loadAdmissionDocuments();
            }
            if (step === 2) {
                loadStudentPicture();
            }
            clearError();
        }

        function saveStep(step) {
            var postData = $('#admission-form').serializeArray();
            postData.push({ name: 'step', value: step });

            return $.ajax({
                cache: false,
                type: 'POST',
                url: '@Url.Action("SaveStep", "Admission")',
                data: postData
            });
        }

        function loadByFormNo(nextStep) {
            var formNo = $('#@Html.IdFor(model => model.FormNo)').val();
            if (!formNo || loadingFormNo) {
                return;
            }

            loadingFormNo = true;
            var postData = { formNo: formNo };
            addAntiForgeryToken(postData);

            $.ajax({
                cache: false,
                type: 'POST',
                url: '@Url.Action("LoadByFormNo", "Admission")',
                data: postData,
                success: function (data) {
                    if (!data.success) {
                        showError(data.message);
                        return;
                    }

                    if (!data.id) {
                        $('#@Html.IdFor(model => model.Id)').val(0);
                        $('#@Html.IdFor(model => model.SRN)').val('');
                        showStep(nextStep || 1);
                        return;
                    }

                    if ($('#@Html.IdFor(model => model.Id)').val() !== data.id.toString()) {
                        window.location.href = data.editUrl + '#step-' + (nextStep || 2);
                        return;
                    }

                    $('#@Html.IdFor(model => model.SRN)').val(data.srn || '');
                    showStep(nextStep || 2);
                },
                error: function () {
                    showError('Could not load admission form.');
                },
                complete: function () {
                    loadingFormNo = false;
                }
            });
        }

        function clearDocumentPonds() {
            Object.keys(documentPonds).forEach(function (key) {
                documentPonds[key].destroy();
            });
            documentPonds = {};
        }

        function updateStudentPicture(data) {
            var documentId = data.documentId || 0;
            var previewUrl = data.previewUrl || '';
            var fileName = data.fileName || '';
            var hasPicture = documentId > 0 && previewUrl;

            $('#admission-student-picture-preview')
                .attr('src', hasPicture ? previewUrl : '')
                .toggle(hasPicture);
            $('#admission-student-picture-empty').toggle(!hasPicture);
            $('#admission-student-picture-view').attr('href', hasPicture ? previewUrl : '#').toggle(hasPicture);
            $('#admission-student-picture-remove').attr('data-document-id', documentId).toggle(hasPicture);
            $('#admission-student-picture-file-name').text(fileName);
        }

        function initStudentPictureUploader() {
            if (studentPicturePond) {
                return;
            }

            if (!window.FilePond) {
                setTimeout(initStudentPictureUploader, 100);
                return;
            }

            studentPicturePond = FilePond.create(document.querySelector('#admission-student-picture-upload'), {
                credits: false,
                allowMultiple: false,
                maxFiles: 1,
                acceptedFileTypes: ['image/*'],
                server: {
                    process: function (fieldName, file, metadata, load, error, progress, abort) {
                        var admissionId = $('#@Html.IdFor(model => model.Id)').val();
                        if (!admissionId || admissionId === '0') {
                            error('Please save the form no. and grade first.');
                            return {
                                abort: function () {
                                    abort();
                                }
                            };
                        }

                        var formData = new FormData();
                        formData.append('admissionId', admissionId);
                        formData.append('file', file, file.name);
                        formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

                        var request = new XMLHttpRequest();
                        request.open('POST', '@Url.Action("UploadStudentPicture", "Admission")');
                        request.upload.onprogress = function (event) {
                            progress(event.lengthComputable, event.loaded, event.total);
                        };
                        request.onload = function () {
                            var response = JSON.parse(request.responseText || '{}');
                            if (request.status >= 200 && request.status < 300 && response.success) {
                                updateStudentPicture(response);
                                load(response.documentId);
                            } else {
                                error(response.message || 'Could not upload student picture.');
                            }
                        };
                        request.onerror = function () {
                            error('Could not upload student picture.');
                        };
                        request.send(formData);

                        return {
                            abort: function () {
                                request.abort();
                                abort();
                            }
                        };
                    }
                },
                labelIdle: '@T("Common.FileUploader.DropFiles") / <span class="filepond--label-action">@T("Common.FileUploader.Browse")</span>',
                labelFileProcessing: '@T("Common.FileUploader.Processing")'
            });
        }

        function loadStudentPicture(force) {
            var admissionId = Number($('#@Html.IdFor(model => model.Id)').val());
            initStudentPictureUploader();

            if (!admissionId) {
                updateStudentPicture({});
                return;
            }

            if (!force && pictureLoadedForAdmissionId === admissionId) {
                return;
            }

            var postData = { admissionId: admissionId };
            addAntiForgeryToken(postData);

            $.ajax({
                cache: false,
                type: 'POST',
                url: '@Url.Action("StudentPicture", "Admission")',
                data: postData,
                success: function (data) {
                    if (!data.success) {
                        showError(data.message);
                        return;
                    }

                    pictureLoadedForAdmissionId = admissionId;
                    updateStudentPicture(data);
                },
                error: function () {
                    showError('Could not load student picture.');
                }
            });
        }

        function getAdmissionDocumentValue(admissionDocument, camelCaseName, pascalCaseName) {
            return admissionDocument[camelCaseName] !== undefined
                ? admissionDocument[camelCaseName]
                : admissionDocument[pascalCaseName];
        }

        function normalizeAdmissionDocument(admissionDocument) {
            return {
                admissionDocumentTypeId: getAdmissionDocumentValue(admissionDocument, 'admissionDocumentTypeId', 'AdmissionDocumentTypeId'),
                admissionDocumentTypeName: getAdmissionDocumentValue(admissionDocument, 'admissionDocumentTypeName', 'AdmissionDocumentTypeName'),
                isRequired: getAdmissionDocumentValue(admissionDocument, 'isRequired', 'IsRequired') === true,
                admissionDocumentId: getAdmissionDocumentValue(admissionDocument, 'admissionDocumentId', 'AdmissionDocumentId') || 0,
                fileName: getAdmissionDocumentValue(admissionDocument, 'fileName', 'FileName') || '',
                previewUrl: getAdmissionDocumentValue(admissionDocument, 'previewUrl', 'PreviewUrl') || ''
            };
        }

        function renderDocumentRow(admissionDocument) {
            admissionDocument = normalizeAdmissionDocument(admissionDocument);

            var rowId = 'admission-document-row-' + admissionDocument.admissionDocumentTypeId;
            var inputId = 'admission-document-upload-' + admissionDocument.admissionDocumentTypeId;
            var requiredBadge = admissionDocument.isRequired
                ? '<span class="badge badge-danger ml-2">Required</span>'
                : '<span class="badge badge-secondary ml-2">Optional</span>';
            var fileName = admissionDocument.fileName || '';
            var hasDocument = admissionDocument.admissionDocumentId > 0;
            var previewStyle = hasDocument ? '' : 'display:none';
            var removeStyle = hasDocument ? '' : 'display:none';

            var $row = $('<div class="card card-default mb-3 admission-document-row" />').attr('id', rowId);
            var $header = $('<div class="card-header d-flex align-items-center justify-content-between" />');
            var $title = $('<div />').text(admissionDocument.admissionDocumentTypeName).append(requiredBadge);
            var $actions = $('<div />');
            var $preview = $('<a class="btn btn-default btn-sm admission-document-preview" target="_blank" title="Preview"><i class="far fa-eye"></i></a>')
                .attr('href', admissionDocument.previewUrl || '#')
                .attr('style', previewStyle);
            var $remove = $('<button type="button" class="btn btn-danger btn-sm admission-document-remove ml-2" title="Remove"><i class="far fa-trash-can"></i></button>')
                .attr('style', removeStyle)
                .attr('data-document-id', admissionDocument.admissionDocumentId);
            var $body = $('<div class="card-body" />');
            var $fileName = $('<div class="text-muted mb-2 admission-document-file-name" />').text(fileName);
            var $input = $('<input type="file" />')
                .attr('id', inputId)
                .attr('name', inputId)
                .attr('accept', 'image/*,.pdf,application/pdf');

            $actions.append($preview).append($remove);
            $header.append($title).append($actions);
            $body.append($fileName).append($input);
            $row.append($header).append($body);

            $('#admission-documents-list').append($row);

            var pond = FilePond.create(document.querySelector('#' + inputId), {
                credits: false,
                allowMultiple: false,
                maxFiles: 1,
                acceptedFileTypes: ['image/*', 'application/pdf'],
                server: {
                    process: function (fieldName, file, metadata, load, error, progress, abort) {
                        var formData = new FormData();
                        formData.append('admissionId', $('#@Html.IdFor(model => model.Id)').val());
                        formData.append('admissionDocumentTypeId', admissionDocument.admissionDocumentTypeId);
                        formData.append('file', file, file.name);
                        formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

                        var request = new XMLHttpRequest();
                        request.open('POST', '@Url.Action("UploadDocument", "Admission")');
                        request.upload.onprogress = function (event) {
                            progress(event.lengthComputable, event.loaded, event.total);
                        };
                        request.onload = function () {
                            var response = JSON.parse(request.responseText || '{}');
                            if (request.status >= 200 && request.status < 300 && response.success) {
                                var $row = $('#' + rowId);
                                $row.find('.admission-document-file-name').text(response.fileName);
                                $row.find('.admission-document-preview').attr('href', response.previewUrl).show();
                                $row.find('.admission-document-remove').attr('data-document-id', response.documentId).show();
                                load(response.documentId);
                            } else {
                                error(response.message || 'Could not upload document.');
                            }
                        };
                        request.onerror = function () {
                            error('Could not upload document.');
                        };
                        request.send(formData);

                        return {
                            abort: function () {
                                request.abort();
                                abort();
                            }
                        };
                    }
                },
                labelIdle: '@T("Common.FileUploader.DropFiles") / <span class="filepond--label-action">@T("Common.FileUploader.Browse")</span>',
                labelFileProcessing: '@T("Common.FileUploader.Processing")'
            });

            documentPonds[admissionDocument.admissionDocumentTypeId] = pond;
        }

        function loadAdmissionDocuments(force) {
            var admissionId = Number($('#@Html.IdFor(model => model.Id)').val());
            if (!admissionId) {
                showError('Please save the form no. and grade first.');
                return;
            }

            if (!force && documentsLoadedForAdmissionId === admissionId) {
                return;
            }

            $('#admission-documents-loading').show();
            $('#admission-documents-empty').hide();
            $('#admission-documents-list').empty();
            clearDocumentPonds();

            var postData = { admissionId: admissionId };
            addAntiForgeryToken(postData);

            $.ajax({
                cache: false,
                type: 'POST',
                url: '@Url.Action("RequiredDocuments", "Admission")',
                data: postData,
                success: function (data) {
                    if (!data.success) {
                        showError(data.message);
                        return;
                    }

                    documentsLoadedForAdmissionId = admissionId;
                    var documents = data.documents || [];
                    $('#admission-documents-empty').toggle(documents.length === 0);
                    documents.forEach(renderDocumentRow);
                },
                error: function () {
                    showError('Could not load admission documents.');
                },
                complete: function () {
                    $('#admission-documents-loading').hide();
                }
            });
        }

        $('.admission-step-list button').on('click', function () {
            var step = Number($(this).data('admission-step'));
            if (step === 5 && !guardianIsOther()) {
                return;
            }
            showStep(step);
        });

        $('#@Html.IdFor(model => model.FormNo)').on('change blur', function () {
            loadByFormNo(1);
        });

        $('#@Html.IdFor(model => model.GradeId)').on('change', function () {
            documentsLoadedForAdmissionId = 0;
        });

        $('#@Html.IdFor(model => model.GuardianTypeId)').on('change', refreshGuardianStep);

        $('#admission-save-step').on('click', function () {
            if (currentStep === 1) {
                saveStep(1).done(function (data) {
                    if (!data.success) {
                        showError(data.message);
                        return;
                    }

                    $('#@Html.IdFor(model => model.Id)').val(data.id);
                    $('#@Html.IdFor(model => model.SRN)').val(data.srn || '');
                    showStep(2);
                }).fail(function () {
                    showError('Could not save admission step.');
                });

                return;
            }

            saveStep(currentStep).done(function (data) {
                if (!data.success) {
                    showError(data.message);
                    return;
                }

                $('#@Html.IdFor(model => model.Id)').val(data.id);
                $('#@Html.IdFor(model => model.SRN)').val(data.srn || $('#@Html.IdFor(model => model.SRN)').val());

                var nextStep = currentStep + 1;
                if (currentStep === 4 && !guardianIsOther()) {
                    showStep(6);
                    return;
                }

                if (nextStep <= 6) {
                    showStep(nextStep);
                }
            }).fail(function () {
                showError('Could not save admission step.');
            });
        });

        $('#admission-form').on('submit', function (event) {
            event.preventDefault();
        });

        $('#admission-documents-list').on('click', '.admission-document-remove', function () {
            var $button = $(this);
            var documentId = Number($button.attr('data-document-id'));
            if (!documentId) {
                return;
            }

            var postData = { id: documentId };
            addAntiForgeryToken(postData);

            $.ajax({
                cache: false,
                type: 'POST',
                url: '@Url.Action("DeleteDocument", "Admission")',
                data: postData,
                success: function (data) {
                    if (!data.success) {
                        showError(data.message);
                        return;
                    }

                    loadAdmissionDocuments(true);
                },
                error: function () {
                    showError('Could not remove document.');
                }
            });
        });

        $('#admission-student-picture-remove').on('click', function () {
            var documentId = Number($(this).attr('data-document-id'));
            if (!documentId) {
                return;
            }

            var postData = { id: documentId };
            addAntiForgeryToken(postData);

            $.ajax({
                cache: false,
                type: 'POST',
                url: '@Url.Action("DeleteDocument", "Admission")',
                data: postData,
                success: function (data) {
                    if (!data.success) {
                        showError(data.message);
                        return;
                    }

                    updateStudentPicture({});
                    pictureLoadedForAdmissionId = 0;
                    if (studentPicturePond) {
                        studentPicturePond.removeFiles();
                    }
                },
                error: function () {
                    showError('Could not remove student picture.');
                }
            });
        });

        var hashStep = Number((window.location.hash || '').replace('#step-', ''));
        showStep(hashStep > 0 ? hashStep : 1);
    });
</script>
