@using Nop.Core.Domain.GenericDropDowns
@using Nop.Web.Areas.Admin.Models.Admissions
@using Nop.Web.Areas.Admin.Models.Common
@model AdmissionModel

<link rel="stylesheet" href="~/lib_npm/filepond/filepond.min.css" />
<script asp-exclude-from-bundle="true" src="~/lib_npm/filepond/filepond.min.js" asp-location="Footer"></script>

<input asp-for="Id" type="hidden" />
<input asp-for="CreatedBy" type="hidden" />
<input asp-for="CreatedOnUtc" type="hidden" />
<input asp-for="UpdatedBy" type="hidden" />
<input asp-for="UpdatedOnUtc" type="hidden" />
<input asp-for="Deleted" type="hidden" />

<div class="card-body">
    <div id="admission-step-alert" class="alert alert-danger" style="display:none"></div>
    <div class="row">
        <div class="col-md-3">
            <div class="list-group admission-step-list">
                <button type="button" class="list-group-item list-group-item-action active" data-admission-step="1">@T("Admin.Configuration.Admissions.Fields.FormNo")</button>
                <button type="button" class="list-group-item list-group-item-action" data-admission-step="2">Student Information</button>
                <button type="button" class="list-group-item list-group-item-action" data-admission-step="3">Father Information</button>
                <button type="button" class="list-group-item list-group-item-action" data-admission-step="4">Mother Information</button>
                <button type="button" class="list-group-item list-group-item-action" data-admission-step="5" id="guardian-step-link">Guardian Information</button>
                <button type="button" class="list-group-item list-group-item-action" data-admission-step="6">Documents</button>
            </div>
        </div>
        <div class="col-md-9">
            <div class="admission-step-panel" data-admission-panel="1">
                <div class="form-group row">
                    <div class="col-md-3"><nop-label asp-for="FormNo" /></div>
                    <div class="col-md-9">
                        <nop-editor asp-for="FormNo" />
                        <span asp-validation-for="FormNo"></span>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><nop-label asp-for="SRN" /></div>
                    <div class="col-md-9">
                        <input asp-for="SRN" class="form-control" readonly="readonly" />
                        <span asp-validation-for="SRN"></span>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><nop-label asp-for="GradeId" /></div>
                    <div class="col-md-9">
                        <nop-select asp-for="GradeId" asp-items="Model.AvailableGrades" />
                        <span asp-validation-for="GradeId"></span>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-md-3"><nop-label asp-for="StatusId" /></div>
                    <div class="col-md-9">
                        @await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.StatusId), FieldId = Html.IdFor(model => model.StatusId), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableAdmissionStatuses, SelectedValue = Model.StatusId.ToString(), Category = GenericDropdownEntity.AdmissionStatus.ToString() })
                        <span asp-validation-for="StatusId"></span>
                    </div>
                </div>
            </div>

            <div class="admission-step-panel" data-admission-panel="2" style="display:none">
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="FirstName" /></div><div class="col-md-9"><nop-editor asp-for="FirstName" /><span asp-validation-for="FirstName"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="MiddleName" /></div><div class="col-md-9"><nop-editor asp-for="MiddleName" /><span asp-validation-for="MiddleName"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="LastName" /></div><div class="col-md-9"><nop-editor asp-for="LastName" /><span asp-validation-for="LastName"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="CNIC" /></div><div class="col-md-9">@await Html.PartialAsync("_CnicInput", new CnicInputModel { FieldName = nameof(Model.CNIC), FieldId = Html.IdFor(model => model.CNIC), Value = Model.CNIC })<span asp-validation-for="CNIC"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="PreviousSchoolId" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.PreviousSchoolId), FieldId = Html.IdFor(model => model.PreviousSchoolId), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailablePreviousSchools, SelectedValue = Model.PreviousSchoolId.ToString(), Category = GenericDropdownEntity.PreviousSchoolName.ToString() })<span asp-validation-for="PreviousSchoolId"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="IdentificationMark" /></div><div class="col-md-9"><nop-editor asp-for="IdentificationMark" /><span asp-validation-for="IdentificationMark"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="DateOfBirth" /></div><div class="col-md-9"><nop-editor asp-for="DateOfBirth" /><span asp-validation-for="DateOfBirth"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="BirthCity" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.BirthCity), FieldId = Html.IdFor(model => model.BirthCity), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableBirthCities, SelectedValue = Model.BirthCity.ToString(), Category = GenericDropdownEntity.BirthCity.ToString() })<span asp-validation-for="BirthCity"></span></div></div>
                <div class="form-group row">
                    <div class="col-md-3">@T("Admin.Configuration.Admissions.Fields.StudentPicture")</div>
                    <div class="col-md-9">
                        <div class="d-flex align-items-start">
                            <div class="border rounded bg-light mr-3 d-flex align-items-center justify-content-center" style="width:120px;height:140px;overflow:hidden;">
                                <img id="admission-student-picture-preview" src="" alt="" style="display:none;max-width:100%;max-height:100%;" />
                                <span id="admission-student-picture-empty" class="text-muted small">@T("Admin.Common.No")</span>
                            </div>
                            <div class="flex-grow-1">
                                <div class="mb-2">
                                    <a id="admission-student-picture-view" href="#" class="btn btn-default btn-sm" target="_blank" style="display:none">
                                        <i class="far fa-eye"></i>
                                        @T("Admin.Common.View")
                                    </a>
                                    <button type="button" id="admission-student-picture-remove" class="btn btn-danger btn-sm ml-2" style="display:none">
                                        <i class="far fa-trash-can"></i>
                                        @T("Admin.Common.Delete")
                                    </button>
                                </div>
                                <input type="file" id="admission-student-picture-upload" accept="image/*" />
                                <div id="admission-student-picture-file-name" class="text-muted mt-2"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="Address" /></div><div class="col-md-9"><nop-textarea asp-for="Address" /><span asp-validation-for="Address"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="SiblingsCount" /></div><div class="col-md-9"><nop-editor asp-for="SiblingsCount" /><span asp-validation-for="SiblingsCount"></span></div></div>
