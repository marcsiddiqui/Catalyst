                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="Allergies" /></div><div class="col-md-9"><nop-editor asp-for="Allergies" /><span asp-validation-for="Allergies"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="MedicalNotes" /></div><div class="col-md-9"><nop-editor asp-for="MedicalNotes" /><span asp-validation-for="MedicalNotes"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="MontherTongue" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.MontherTongue), FieldId = Html.IdFor(model => model.MontherTongue), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableMotherTongues, SelectedValue = Model.MontherTongue.ToString(), Category = GenericDropdownEntity.MotherTounge.ToString() })<span asp-validation-for="MontherTongue"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="Nationality" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.Nationality), FieldId = Html.IdFor(model => model.Nationality), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableNationalities, SelectedValue = Model.Nationality.ToString(), Category = GenericDropdownEntity.Nationality.ToString() })<span asp-validation-for="Nationality"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="Religion" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.Religion), FieldId = Html.IdFor(model => model.Religion), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableReligions, SelectedValue = Model.Religion.ToString(), Category = GenericDropdownEntity.Religion.ToString() })<span asp-validation-for="Religion"></span></div></div>
                <div class="form-group row"><div class="col-md-3"><nop-label asp-for="BloodGroup" /></div><div class="col-md-9">@await Html.PartialAsync("_SearchableSelect", new SearchableSelectModel { FieldName = nameof(Model.BloodGroup), FieldId = Html.IdFor(model => model.BloodGroup), Placeholder = T("Admin.Common.Select").Text, Items = Model.AvailableBloodGroups, SelectedValue = Model.BloodGroup.ToString(), Category = GenericDropdownEntity.BloodGroup.ToString() })<span asp-validation-for="BloodGroup"></span></div></div>
