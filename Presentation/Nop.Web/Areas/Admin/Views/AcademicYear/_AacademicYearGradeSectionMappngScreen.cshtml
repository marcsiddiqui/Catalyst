@using Nop.Web.Areas.Admin.Models.AcademicYears
@using Nop.Web.Areas.Admin.Models.GradeManagement
@model AcademicYearModel

<div class="card card-default">
    <div class="card-header">
        @T("Admin.Configuration.AcademicYears.Grade.Section.Mapping")
    </div>
    @if (Model.Id > 0)
    {
        <div class="card-body">
            <p>
                @T("Admin.Configuration.AcademicYears.Grade.Section.Mapping.Hint")
            </p>
            @await Html.PartialAsync("Table", new DataTablesModel
            {
                Name = "academicYearGradeSectionMapping-grid",
                UrlRead = new DataUrl("AcademicYearGradeSectionMappingGrid", "AcademicYear", new RouteValueDictionary { [nameof(Model.AcademicYearGradeSectionMappingSearchModel.AcademicYearId)] = Model.AcademicYearGradeSectionMappingSearchModel.AcademicYearId }),
                UrlDelete = new DataUrl("AcademicYearGradeSectionMappingDelete", "AcademicYear", null),
                Length = Model.AcademicYearGradeSectionMappingSearchModel.PageSize,
                LengthMenu = Model.AcademicYearGradeSectionMappingSearchModel.AvailablePageSizes,
                ColumnCollection = new List<ColumnProperty>
                {
                    new ColumnProperty(nameof(AcademicYearGradeSectionMappingModel.GradeName))
                    {
                        Title = T("Admin.Configuration.AcademicYears.Grade.Section.Mapping.GradeName").Text
                    },
                    new ColumnProperty(nameof(AcademicYearGradeSectionMappingModel.SectionName))
                    {
                        Title = T("Admin.Configuration.AcademicYears.Grade.Section.Mapping.SectionName").Text
                    },
                    new ColumnProperty(nameof(AcademicYearGradeSectionMappingModel.ExamTermCount))
                    {
                        Title = T("Admin.Configuration.AcademicYears.Grade.Section.Mapping.ExamTermCount").Text
                    },
                    new ColumnProperty(nameof(AcademicYearGradeSectionMappingModel.Id))
                    {
                        Title = T("Admin.Common.Edit").Text,
                        Width = "100",
                        ClassName =  NopColumnClassDefaults.Button,
                        Render = new RenderCustom("renderAcademicYearGradeSectionEditColumn")
                    },
                    new ColumnProperty(nameof(AcademicYearGradeSectionMappingModel.Id))
                    {
                        Title = T("Admin.Common.Delete").Text,
                        Width = "100",
                        Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                        ClassName =  NopColumnClassDefaults.Button
                    }
                }
            })
            <script>
                function renderAcademicYearGradeSectionEditColumn(data, type, row, meta) {
                    return '<button onclick=\"javascript:OpenWindow(\'@Url.Content("~/Admin/Grade/AddOrEditGradeSubjectMappingPopup/")' + data + '?academicYearId=' + @Model.Id + '&mappingId=' + row.Id + '\', 800, 600, true); return false;\" class="btn btn-default"><i class="fas fa-pencil"></i>@T("Admin.Common.Edit").Text</button>';
                }
            </script>
        </div>
        <div class="card-footer">
            <button type="submit" id="btnAddNewAcademicYearGradeSectionMapping" onclick="javascript:OpenWindow('@(Url.Action("AddOrEditAcademicYearGradeSectionMappingPopup", "AcademicYear", new { academicYearId = Model.Id, mappingId = 0}))', 800, 600, true); return false;" class="btn btn-primary">
                @T("Admin.Configuration.AcademicYears.Grade.Section.Mapping.AddNew")
            </button>
            <button type="submit" id="btnToLoadAcademicYearGradeSectionMapping" style="display: none"></button>
            <script>
                $(function() {
                    $('#btnToLoadAcademicYearGradeSectionMapping').click(function () {
                    updateTable('#academicYearGradeSectionMapping-grid');
                        //return false to don't reload a page
                        return false;
                    });
                });
            </script>
        </div>
    }
    else
    {
        <div class="card-body">
            @T("Admin.Configuration.AcademicYears.Grade.Section.Mapping.SaveBeforeEdit")
        </div>
    }
</div>