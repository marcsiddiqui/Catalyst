@model BaseNopEntityModel

@if (Model.Id > 0)
{
    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="CreatedByName" />
        </div>
        <div class="col-md-9 align-content-center">
            @Model.CreatedByName
        </div>
    </div>

    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="CreatedOnUtc" />
        </div>
        <div class="col-md-9 align-content-center">
            @Model.CreatedOnUtc
        </div>
    </div>

    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="UpdatedByName" />
        </div>
        <div class="col-md-9 align-content-center">
            @Model.UpdatedByName
        </div>
    </div>

    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="UpdatedOnUtc" />
        </div>
        <div class="col-md-9 align-content-center">
            @Model.UpdatedOnUtc
        </div>
    </div>
}