@using Nop.Web.Framework.Menu

@inject IAdminMenu siteMap;

@* Phoenix admin integration start: additional class for scoped sidebar styling; treeview remains AdminLTE. *@
<ul class="nav nav-pills nav-sidebar flex-column nav-legacy phoenix-nop-nav" data-widget="treeview" role="menu">
    @{
        //display menu items
        foreach (var item in (await siteMap.GetRootNodeAsync()).ChildNodes.Where(n => n.Visible))
        {
            @await Html.PartialAsync("_MenuItem", item)
        }
    }
</ul>
@* Phoenix admin integration end *@
